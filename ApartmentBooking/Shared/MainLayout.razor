@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@using ApartmentBooking.Services

<div class="layout">
    <nav class="navbar">
        <a href="/" class="brand">ApartRent</a>
        <div class="nav-links">
            <a href="/search">Поиск</a>
            <a href="/help">Справка</a>
            @if (Auth.IsLoggedIn)
            {
                <a href="/my-apartments">Мои квартиры</a>
                <a href="/my-bookings">Мои бронирования</a>
                <span class="user-name">@Auth.UserName</span>
                <button @onclick="Logout" class="btn-logout">Выйти</button>
            }
            else
            {
                <a href="/login">Войти</a>
                <a href="/register" class="btn-register">Регистрация</a>
            }
        </div>
    </nav>
    <main class="content">
        @Body
    </main>
</div>

@code {
    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/");
    }
}